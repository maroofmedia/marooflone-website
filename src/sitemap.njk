---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for page in collections.all | sort(attribute='url') %}
{%- if page.url
      and page.url != '/404/'
      and page.url != '/404.html/'
      and page.url != '/admin/'
      and page.url != '/hi/'
      and not page.data.draft
      and not page.data.noindex
      and '/tags/' not in page.url %}
  <url>
    <loc>{{ page.url | htmlBaseUrl(site.url) }}</loc>
    <lastmod>{{ page.date.toISOString() }}</lastmod>
{%- if page.url == '/' %}
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
{%- elif '/blog/' in page.url and page.url != '/blog/' %}
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
{%- elif page.url == '/blog/' %}
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
{%- else %}
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
{%- endif %}
  </url>
{%- endif %}
{%- endfor %}
</urlset>
